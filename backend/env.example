# SafePsy Landing Page Environment Configuration

# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Privacy & Security
# IP hashing for privacy protection (default: OFF for maximum privacy)
IP_HASHING_ENABLED=false

# Generate a secure random salt for IP hashing
# Use: openssl rand -hex 32
IP_SALT=your-secure-random-salt-here

# Analytics (Optional)
PLAUSIBLE_DOMAIN=safepsy.com

# Production overrides (uncomment for production)
# NODE_ENV=production
# DATABASE_URL="postgresql://user:password@localhost:5432/safepsy_prod"
# FRONTEND_URL=https://safepsy.com
# PLAUSIBLE_DOMAIN=safepsy.com

# Staging overrides (uncomment for staging)
# NODE_ENV=staging
# DATABASE_URL="postgresql://user:password@localhost:5432/safepsy_staging"
# FRONTEND_URL=https://staging.safepsy.com
# PLAUSIBLE_DOMAIN=staging.safepsy.com

# DID (Decentralized Identity) Configuration
# For full blockchain/DID config, see root env.example
# Sepolia: see apps/api/deployments/sepolia-latest.json
#   Registry:  0x8e5F41f2B8B3E28a8966e37181B257f9E2725bA5
#   Ownership: 0xac5Ad1482d73d0E09ED3960C02EebF428Ad63722
# DID_REGISTRY_ADDRESS=0x8e5F41f2B8B3E28a8966e37181B257f9E2725bA5
# DID_OWNERSHIP_ADDRESS=0xac5Ad1482d73d0E09ED3960C02EebF428Ad63722
