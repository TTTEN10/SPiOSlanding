# Local deployment run artifacts (not source of truth)
deployment/deployment-logs/

# Deployment files that may contain server IPs or credentials
# Note: Deployment scripts with hardcoded IPs should be reviewed
# but are kept for operational purposes - consider using environment variables

# Hardhat/Blockchain files
# Note: Deployment JSON files typically only contain public addresses (safe to commit)
# But local deployment files might contain sensitive info - review before committing
apps/api/.openzeppelin/
apps/api/cache/
apps/api/artifacts/
# Only ignore deployment files if they contain private keys (review manually)
# apps/api/deployments/local-*.json

# Google service account credentials
*-service-account*.json
google-credentials.json
service-account*.json

# AWS credentials
.aws/
aws-credentials
aws-config

# Self-healing monitor runtime state (local clone; server uses /opt/spapp-monitor/state|lock)
.lock/deploy.lock
.lock/monitor_state

# Scaleway credentials
.scaleway/
scaleway-credentials

# Secret Manager setup files with credentials
SINGLE_SECRET_SETUP.md

# SSH keys (private keys only - public keys are generally safe to commit)
id_rsa
id_ed25519
id_ecdsa
id_dsa
id_rsa_*
id_ed25519_*
id_ecdsa_*
id_dsa_*
ssh_key
ssh-key
