# SafePsy Landing Page Environment Configuration

# Copy this file to .env and update the values
# 
# IMPORTANT: Secret management is disabled. All secrets must be set as environment variables.
# Manage all API keys and secrets manually (e.g., on paper or secure password manager).
# Never commit .env files to version control.

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# For production, use PostgreSQL (recommended):
# DATABASE_URL="postgresql://safepsy_user:YOUR_PASSWORD@localhost:5432/safepsy_dev"
# Or construct from components:
# POSTGRES_PASSWORD=your-secure-password
# DATABASE_URL="postgresql://safepsy_user:${POSTGRES_PASSWORD}@localhost:5432/safepsy_dev"
#
# Local development (matches docker-compose.local.yml):
# DATABASE_URL="postgresql://safepsy:safepsy_local_dev_password_2026@localhost:5433/safepsy_dev"

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# Content Security Policy (API responses)
# Default connect-src is 'self'. Only set this if you intentionally need cross-origin browser calls.
# Comma-separated list of origins.
# CSP_CONNECT_SRC=https://api.safepsy.com
# CSP_CONNECT_SRC=

# Privacy & Security
# IP hashing for privacy protection (default: OFF for maximum privacy)
IP_HASHING_ENABLED=false

# Generate a secure random salt for IP hashing
# CRITICAL: Use a strong random salt (at least 32 characters)
# Generate with: openssl rand -hex 32
# IP_SALT=your-secure-random-salt-change-this-in-production

# Analytics (Optional)
# Leave empty to disable Plausible Analytics
PLAUSIBLE_DOMAIN=safepsy.com

# Email Configuration
# Enable confirmation email pipeline (default: false)
ENABLE_CONFIRMATION_EMAIL=false

# Email Provider: 'ses', 'postmark', or 'stub' (default: 'stub' for development)
# Use 'stub' for development/testing (logs emails instead of sending)
EMAIL_PROVIDER=stub

# Email From Address (used by all providers)
EMAIL_FROM_ADDRESS=noreply@safepsy.com

# AWS SES Configuration (if EMAIL_PROVIDER=ses)
# AWS Access Key ID for SES
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS Secret Access Key for SES
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS Region for SES (e.g., us-east-1, eu-west-1)
AWS_REGION=us-east-1
# Alternative: SES-specific from address (overrides EMAIL_FROM_ADDRESS)
# SES_FROM_ADDRESS=noreply@safepsy.com

# Postmark Configuration (if EMAIL_PROVIDER=postmark)
# Postmark API Token (get from https://account.postmarkapp.com/servers)
# POSTMARK_API_TOKEN=your-postmark-api-token
# Alternative: Postmark-specific from address (overrides EMAIL_FROM_ADDRESS)
# POSTMARK_FROM_ADDRESS=noreply@safepsy.com

# Google Sheets — when configured, /api/subscribe rows are written here; otherwise signups go to Postgres only.
# Sheet ID from URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit (optional; defaults in code if unset)
GOOGLE_SHEETS_ID=1SgLzzBLluvvgF-k55jVC8Om8JxK6Ookyp-r6KXAL-D0
# Tab name in the spreadsheet (default "Subscriptions")
GOOGLE_SHEETS_TAB_NAME=Subscriptions
# Recommended (Docker): path to service account JSON inside the container. Mount the file in compose; share the sheet with the service account (Editor).
# GOOGLE_SHEETS_CREDENTIALS_FILE=/run/secrets/google-sheets-sa.json
# Alternative: one-line JSON in .env (private_key may use \n for newlines), or a host path to the key file
# GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}
# GOOGLE_SHEETS_CREDENTIALS=/path/to/service-account-key.json
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_CREDENTIALS_FILE=

# Scaleway API Configuration
# Scaleway API key for chat completions (required for AI chat functionality)
# Get your API key from: https://console.scaleway.com/iam/api-keys
SCALEWAY_API_KEY=your-scaleway-api-key-here

# Scaleway Chat Model Configuration
# Model ID for Scaleway Generative API (e.g., mistral-large, llama-3-70b-instruct)
# SCALEWAY_CHAT_MODEL=mistral-large
# SCALEWAY_CHAT_MODEL_ID=meta-llama/llama-3-70b-instruct

# Chatbot Configuration (Optional - for external chatbot service)
# Base URL for external chatbot service (if not using Scaleway)
# CHATBOT_BASE_URL=https://your-chatbot-service.com
# CHATBOT_INTERNAL_API_KEY=your-internal-api-key

# AI GPU Service Configuration (Optional - for self-hosted GPU AI service)
# Base URL for GPU AI service (e.g., http://gpu-instance-ip:8000)
# If not set, backend will use Scaleway Generative API as fallback
# AI_GPU_BASE_URL=http://localhost:8000

# AI Internal API Key (for authenticating with GPU AI service)
# Generate with: openssl rand -hex 32
# Must match AI_INTERNAL_API_KEY set in GPU AI service container
# AI_INTERNAL_API_KEY=3f1908c51671a74921344ea40df1144118499d01d4d7138fd2c7ac2ac0c63e64

# AI Upstream Timeout (milliseconds) for chat completions
# AI_UPSTREAM_TIMEOUT_MS=120000

# Scaleway Object Storage credentials (if using Scaleway Object Storage)
# SCALEWAY_ACCESS_KEY=your-scaleway-access-key
# SCALEWAY_SECRET_KEY=your-scaleway-secret-key

# RAG (Retrieval-Augmented Generation) Configuration
# Embedding provider: 'openai' (default) - Note: embeddings still use OpenAI, only chat uses Scaleway
EMBEDDING_PROVIDER=openai
# Embedding model: 'text-embedding-3-small' (1536 dims) or 'text-embedding-3-large' (3072 dims)
EMBEDDING_MODEL=text-embedding-3-small
# OpenAI API Key (required for RAG embeddings)
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here
# Qdrant vector database URL (default: http://localhost:6333)
QDRANT_URL=http://localhost:6333
# Qdrant API key (optional, for authenticated Qdrant instances)
# QDRANT_API_KEY=your-qdrant-api-key

# RAG Admin Access Control
# Admin API key for RAG indexing operations (generate with: openssl rand -hex 32)
# RAG_ADMIN_API_KEY=your-secure-admin-api-key-here
# Admin wallet addresses (comma-separated, lowercase) for RAG indexing
# RAG_ADMIN_WALLETS=0x1234567890123456789012345678901234567890,0xabcdefabcdefabcdefabcdefabcdefabcdefabcd

# Redis Configuration (for Chat Quota System)
# Option 1: Use Redis URL (recommended for cloud Redis services like Upstash, Redis Cloud, etc.)
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://user:password@host:port (for SSL)

# Option 2: Use host/port configuration
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0

# Chat Quota Configuration
# Daily chat quota limit per DID (default: 100)
CHAT_QUOTA_DAILY_LIMIT=100
# Monthly chat quota limit per DID (default: 1000)
CHAT_QUOTA_MONTHLY_LIMIT=1000

# Storage Configuration (Scaleway Object Storage / IPFS for encrypted chat summaries)

# Scaleway Object Storage Configuration (recommended)
SCALEWAY_OBJECT_STORAGE_ENABLED=true
SCALEWAY_BUCKET_NAME=safepsy-chat-summaries
SCALEWAY_REGION=fr-par
# Scaleway Object Storage credentials (required if SCALEWAY_OBJECT_STORAGE_ENABLED=true)
# SCALEWAY_ACCESS_KEY=your-scaleway-access-key
# SCALEWAY_SECRET_KEY=your-scaleway-secret-key
# Available regions: fr-par (Paris), nl-ams (Amsterdam), pl-waw (Warsaw)

# Alternative: AWS S3 Configuration (if not using Scaleway)
# AWS_S3_ENABLED=false
# AWS_S3_BUCKET_NAME=safepsy-chat-summaries
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Alternative: Generic S3-compatible storage
# OBJECT_STORAGE_BUCKET_NAME=safepsy-chat-summaries
# OBJECT_STORAGE_REGION=your-region
# OBJECT_STORAGE_ENDPOINT=https://your-s3-compatible-endpoint.com
# OBJECT_STORAGE_ACCESS_KEY=your-access-key
# OBJECT_STORAGE_SECRET_KEY=your-secret-key

# Enable IPFS storage (optional, for redundancy)
IPFS_ENABLED=false
IPFS_GATEWAY_URL=https://ipfs.io/ipfs

# IPFS Provider Configuration (choose one)
# Option 1: Web3.Storage (recommended)
WEB3_STORAGE_TOKEN=your-web3-storage-token

# Option 2: Pinata
# PINATA_API_KEY=your-pinata-api-key
# PINATA_SECRET_KEY=your-pinata-secret-key

# Storage preference: 's3', 'ipfs', or 'both' (default: 's3')
# Note: 's3' refers to object storage (Scaleway/S3-compatible)
STORAGE_PREFERRED=s3

# Crypto Payment Configuration
# Ethereum address to receive crypto payments (REQUIRED for crypto payments)
# This is the wallet address where all crypto payments (ETH, USDT, USDC) will be sent
CRYPTO_PAYMENT_CONTRACT_ADDRESS=0x4D32FFBA2A7e090a10789fc094572f61E956f809

# Crypto prices for PREMIUM tier (for one-time payments, 30-day access)
# ETH price is dynamically calculated from CoinGecko API (with 2% markup)
# These are fallback values if price oracle fails
CRYPTO_PRICE_PREMIUM_ETH=0.005714
CRYPTO_PRICE_PREMIUM_USDT=20.00
CRYPTO_PRICE_PREMIUM_USDC=20.00

# ERC-20 Token Contract Addresses (Ethereum Mainnet)
# These are the official contract addresses for USDT and USDC on Ethereum Mainnet
USDT_CONTRACT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDC_CONTRACT_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Safety Middleware Configuration
# Injection filter: blocks SQL injection, XSS, command injection, path traversal, NoSQL injection
# Default: enabled (true)
SAFETY_INJECTION_FILTER_ENABLED=true

# Block requests when injection patterns are detected (default: false, sanitizes instead)
# Set to true to block requests with injection attempts
SAFETY_INJECTION_BLOCK=true

# Content moderation: detects profanity, hate speech, threats
# Default: enabled (true)
SAFETY_MODERATION_ENABLED=true

# Block requests when moderation violations are detected (default: false, logs only)
# Set to true to block requests with moderation violations
SAFETY_MODERATION_BLOCK=false

# PII (Personally Identifiable Information) redaction
# Default: enabled (true)
SAFETY_PII_REDACTION_ENABLED=true

# Redact PII in logs (default: false)
# Set to true to redact emails, phones, SSN, credit cards, IPs in logs
SAFETY_PII_REDACT_LOGS=true

# Redact PII in API responses (default: false)
# Set to true to redact PII in responses sent to clients
SAFETY_PII_REDACT_RESPONSES=false

# Blockchain Configuration
# Ethereum RPC endpoint URL (REQUIRED for crypto payments and blockchain interactions)
# Examples:
#   Mainnet: https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
#   Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
#   Alternative: https://eth.llamarpc.com (public, no key needed)
#   Alternative: https://rpc.ankr.com/eth (public, no key needed)
RPC_URL=https://eth.llamarpc.com
# Alternative RPC URL (used as fallback if RPC_URL is not set)
ETH_RPC_URL=https://eth.llamarpc.com

# WalletConnect Configuration (optional - for multi-wallet support)
# Get your Project ID from: https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# DID (Decentralized Identity) Configuration
# Backend signer private key (optional, only needed if backend must sign transactions)
# Generate a new wallet or use an existing one
# WARNING: Keep this secure! Never commit to version control.
# DID_BACKEND_SIGNER_PRIVATE_KEY=0xYourPrivateKeyHere
# DID Identity Token contract address (set after deploying smart contracts)
# DID_IDENTITY_TOKEN_ADDRESS=0xYourContractAddressHere
# Alternative: DID Registry address (if using registry instead of token)
# DID_REGISTRY_ADDRESS=0xYourRegistryAddressHere