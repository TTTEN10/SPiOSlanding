# SafePsy Chatbot (Prod2XSS instance)
# Copy to .env and set values. Never commit .env.

PORT=8000
# Production (recommended): point at external vLLM OpenAI server — FastAPI proxies /v1/* (no in-process model).
# Example: VLLM_OPENAI_BASE_URL=http://10.x.x.x:8000  (private IP of GPU host)
# Optional auth to upstream: UPSTREAM_OPENAI_API_KEY=...
# VLLM_OPENAI_BASE_URL=
# UPSTREAM_OPENAI_API_KEY=
# UPSTREAM_OPENAI_TIMEOUT_S=120
# PROXY_MODEL_DISPLAY_NAME=dphn/Dolphin-Mistral-24B-Venice-Edition

# USE_GPU=true → vLLM on GPU. USE_GPU=false → Hugging Face on CPU (see CPU_MODEL_NAME), not mock.
# Ignored when VLLM_OPENAI_BASE_URL is set (proxy mode).
USE_GPU=false
USE_MOCK_RESPONSES=false
CPU_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
MODEL_NAME=dphn/Dolphin-Mistral-24B-Venice-Edition
MODEL_REVISION=main
# Required for Dolphin / Mistral-class checkpoints in vLLM; clear for Qwen-only runs.
VLLM_TOKENIZER_MODE=mistral

# API key for app backend → chatbot (must match app AI_INTERNAL_API_KEY)
AI_INTERNAL_API_KEY=generate_with_openssl_rand_hex_32

# Optional: session correlation metadata (message count + TTL). Docker compose sets redis://redis:6379/0.
# REDIS_URL=
# SESSION_METADATA_TTL_SEC=86400

# Optional
# LOG_LEVEL=INFO
# MAX_MODEL_LEN=8192
# GPU_MEMORY_UTILIZATION=0.9
# VLLM_TENSOR_PARALLEL_SIZE=1
# VLLM_ENABLE_CHUNKED_PREFILL=true
# VLLM_MAX_NUM_SEQS=256
