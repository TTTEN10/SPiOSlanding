# SafePsy App Stack (Frontend + Backend + Postgres + Caddy)
# Copy to .env and set values. Never commit .env.

# ---------- Database (used by backend) ----------
POSTGRES_USER=safepsy_user
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=safepsy

# Backend DATABASE_URL (must match Postgres; URL-encode password if it contains special chars)
DATABASE_URL=postgresql://safepsy_user:change_me_secure_password@postgres:5432/safepsy

# ---------- App (backend) ----------
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://safepsy.com

# Chatbot (dedicated instance scw-new-psy) — public URL :8000
AI_GPU_BASE_URL=http://62.210.238.160:8000
# CHATBOT_BASE_URL is an alias; set either one
# CHATBOT_BASE_URL=http://62.210.238.160:8000

# API key the backend sends to the chatbot (must match chatbot AI_INTERNAL_API_KEY)
AI_INTERNAL_API_KEY=generate_with_openssl_rand_hex_32

# ---------- Optional ----------
# IP_SALT=optional_32_char_salt_for_ip_hashing
# IP_HASHING_ENABLED=false
# PLAUSIBLE_DOMAIN=safepsy.com
# ENABLE_CONFIRMATION_EMAIL=false
# SCALEWAY_API_KEY=optional_scaleway_api_key
