{
  "name": "safepsy-api",
  "version": "1.0.0",
  "description": "SafePsy landing page API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:contracts": "tsc --noEmit -p tsconfig.contracts.json",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "deploy:contracts": "tsx src/contracts/scripts/deploy-idempotent.ts",
    "smoke-check": "tsx src/contracts/scripts/smoke-check.ts",
    "hh:diag": "hardhat diag",
    "compile": "hardhat compile",
    "test:contracts": "hardhat test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.712.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "@prisma/client": "^6.19.1",
    "@qdrant/js-client-rest": "^1.16.2",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "alchemy-sdk": "^3.0.0",
    "axios": "^1.12.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dompurify": "^3.2.2",
    "dotenv": "^16.4.7",
    "ethers": "^6.15.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "form-data": "^4.0.1",
    "googleapis": "^144.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "joi": "^17.13.3",
    "jsdom": "^24.1.3",
    "jsonwebtoken": "^9.0.3",
    "postmark": "^3.0.23",
    "prisma": "^6.19.1",
    "prom-client": "^15.1.0",
    "siwe": "^2.3.2",
    "solc": "^0.8.28",
    "web3.storage": "^4.0.0",
    "winston": "^3.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/mocha": ">=9.1.0",
    "@types/node": "^25.2.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "chai": "^4.3.10",
    "eslint": "^9.18.0",
    "globals": "^14.0.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.8",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "solidity-coverage": "^0.8.1",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.8"
  }
}
