# SafePsy API Environment Configuration
# Copy to .env and update values. Never commit .env.

# RPC (Sepolia)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Etherscan (for contract verification). Required for: npx hardhat verify --network sepolia ...
# Do not commit; rotate if exposed.
ETHERSCAN_API_KEY=
# Sepolia RPC (for verify scripts and wiring)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Deployer/signer for wire-registry-governance-only.mjs and deployment
# PRIVATE_KEY=0x...

# DID Contracts (Sepolia - new split architecture)
# Prefer DID_REGISTRY_ADDRESS for verification and basic DID operations
DID_REGISTRY_ADDRESS=0x8e5F41f2B8B3E28a8966e37181B257f9E2725bA5
DID_OWNERSHIP_ADDRESS=0xac5Ad1482d73d0E09ED3960C02EebF428Ad63722

# Legacy (profile data: getProfileByOwner, createDid)
# Use when profile/chat data or backend minting is needed
# DID_IDENTITY_TOKEN_ADDRESS=0x103eAd096f898132E138ad228E35296db983A053

# Backend signer (optional, for createDid on legacy contract)
# DID_BACKEND_SIGNER_PRIVATE_KEY=0x...

# Dedicated chatbot (POST /beta/chat → FastAPI on Scaleway).
# CHATBOT_BASE_URL — if it already ends with /chat or /beta/chat, that full URL is used; otherwise /chat is appended.
# Example public path (ensure Caddy routes POST /beta/chat to this API, not the SPA; avoid pointing at the same host without a separate chatbot upstream or you get a loop).
# CHATBOT_BASE_URL=safepsy.com/beta/chat
# CHATBOT_CHAT_URL=https://example.com/full/path/to/chat
# CHATBOT_PRIVATE_IP=10.x.x.x
# CHATBOT_INTERNAL_API_KEY=

# API chat completions: OpenAI-compatible `/v1` base (vLLM container or FastAPI orchestrator).
# Same meaning as CHATBOT_BASE_URL in ops docs; used by `ai-gateway.service` for /api/chat/completions.
# AI_GPU_BASE_URL=http://localhost:8000
# Optional second hop if primary fails (retry + circuit breaker): FastAPI proxy or alternate host.
# AI_CHATBOT_FALLBACK_URL=http://10.x.x.x:8000
# Stricter upstream timeout (ms) for chat completions to self-hosted OpenAI servers.
# AI_UPSTREAM_TIMEOUT_MS=120000
# Must match chatbot `AI_INTERNAL_API_KEY` when the upstream enforces Bearer auth.
# AI_INTERNAL_API_KEY=

# Optional: protect GET /api/chat/upstream-status (send x-ai-status-secret or Bearer).
# AI_UPSTREAM_STATUS_SECRET=

# Periodic probes for /health and /v1/models on AI_GPU_BASE_URL / CHATBOT_BASE_URL (+ optional fallback).
# AI_SKIP_UPSTREAM_HEALTH_CHECK=0
# AI_UPSTREAM_HEALTH_INTERVAL_MS=30000

# Email (Postmark). Stub logs only unless EMAIL_PROVIDER=postmark and token set.
# EMAIL_PROVIDER=stub
# POSTMARK_API_TOKEN=
# EMAIL_FROM_ADDRESS=noreply@safepsy.com
# ENABLE_CONFIRMATION_EMAIL=false

# Admin notifications: waitlist/contact forward to an inbox (e.g. product inbox).
# ENABLE_ADMIN_NOTIFICATION_EMAIL=false
# ADMIN_NOTIFICATION_EMAIL=safepsyoff@gmail.com
