# Copied into app config at build time (Expo public env).
# TestFlight / App Store: point at your production API (HTTPS), e.g. https://api.safepsy.com
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3001

# Same project as apps/web VITE_WALLETCONNECT_PROJECT_ID — https://cloud.walletconnect.com
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=

# HTTPS site used in WalletConnect metadata.url when set (e.g. https://safepsy.com). Omit to fall back to expo-linking URL.
EXPO_PUBLIC_UNIVERSAL_LINK_BASE=

# Production lock: registrable domain shared by API + Universal base (e.g. safepsy.com). Startup logs errors if URLs disagree.
EXPO_PUBLIC_APP_DOMAIN=

# Emergency only (e.g. one-off TestFlight with staging URLs): set "true" to skip the release-build fatal throw from validateProductionEnvironment(). Never ship to App Store with this enabled.
EXPO_PUBLIC_RELAX_DOMAIN_FATAL=

# Future: set "true" to use @walletconnect/modal-react-native instead of default provider (requires code integration).
EXPO_PUBLIC_USE_WALLETCONNECT_MODAL=

# Optional: Sentry DSN for @sentry/react-native (crash + error reporting).
EXPO_PUBLIC_SENTRY_DSN=

# --- TestFlight (EAS) ---
# One-time: cd apps/safepsy-mobile && npm run eas:init   (links an Expo project; writes extra.eas.projectId in app.json)
# Production EXPO_PUBLIC_* for EAS builds: Expo project → Environment variables, or eas env:create (see Expo EAS env docs).
# Build: npm run eas:build:ios -w safepsy-mobile
# Submit to App Store Connect / TestFlight: npm run eas:submit:ios -w safepsy-mobile
# App Store Connect: app record with bundle id com.safepsy.mobile; privacy questionnaire; export compliance (Info.plist sets standard encryption only).

# EAS Build: install `eas-cli`, run `eas build --platform ios` from apps/safepsy-mobile (see eas.json).
# Apple AASA: set real Team ID in apps/web/public/.well-known/apple-app-site-association, deploy, then:
#   cd apps/web && npm run validate:aasa -- https://safepsy.com
