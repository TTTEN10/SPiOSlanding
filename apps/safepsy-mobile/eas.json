{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": false }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.safepsy.com",
        "EXPO_PUBLIC_UNIVERSAL_LINK_BASE": "https://safepsy.com",
        "EXPO_PUBLIC_APP_DOMAIN": "safepsy.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {}
    }
  }
}
