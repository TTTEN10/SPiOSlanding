# Backup & DR Configuration
# Copy this file to backup-config.env and update the values

# Backup Directory
BACKUP_DIR=/backups

# Logging
LOG_FILE=/var/log/safepsy/backup.log

# === MongoDB Backup Configuration ===
MONGODB_BACKUP_ENABLED=true
MONGODB_BACKUP_RETENTION_DAYS=30
MONGODB_BACKUP_COMPRESSION=gzip
MONGODB_BACKUP_ENCRYPT_KEY=your-mongodb-encryption-key-here

# MongoDB Connection
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_AUTH_DB=admin
MONGODB_DATABASES=

# MongoDB Remote Backup (S3)
MONGODB_REMOTE_BACKUP_ENABLED=false
MONGODB_REMOTE_STORAGE_TYPE=s3
MONGODB_S3_BUCKET=safepsy-mongodb-backups
MONGODB_S3_REGION=us-east-1

# === Redis Backup Configuration ===
REDIS_BACKUP_ENABLED=true
REDIS_BACKUP_RETENTION_DAYS=30
REDIS_BACKUP_COMPRESSION=gzip
REDIS_BACKUP_ENCRYPT_KEY=your-redis-encryption-key-here

# Redis Connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis Remote Backup (S3)
REDIS_REMOTE_BACKUP_ENABLED=false
REDIS_REMOTE_STORAGE_TYPE=s3
REDIS_S3_BUCKET=safepsy-redis-backups
REDIS_S3_REGION=us-east-1

# === GPU Image Backup Configuration ===
GPU_BACKUP_ENABLED=true
GPU_BACKUP_RETENTION_DAYS=30
GPU_BACKUP_COMPRESSION=gzip
GPU_BACKUP_ENCRYPT_KEY=your-gpu-encryption-key-here

# GPU Docker Images (space-separated)
GPU_IMAGE_NAMES=
# GPU Docker Volumes (space-separated)
GPU_VOLUME_NAMES=

# GPU Scaleway Snapshot Configuration
GPU_SCALEWAY_SNAPSHOT_ENABLED=false
GPU_SCALEWAY_INSTANCE_IDS=
SCALEWAY_REGION=fr-par

# GPU Remote Backup (S3)
GPU_REMOTE_BACKUP_ENABLED=true
GPU_REMOTE_STORAGE_TYPE=s3
GPU_S3_BUCKET=safepsy-gpu-backups
GPU_S3_REGION=us-east-1

# === AWS/S3 Configuration (for remote backups) ===
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# === DR Configuration ===
DR_MODE=full
DR_S3_BUCKET=safepsy-dr-backups
DR_S3_REGION=us-east-1

# MongoDB DR
MONGODB_DR_HOST=localhost
MONGODB_DR_PORT=27017
MONGODB_DR_USER=
MONGODB_DR_PASSWORD=
MONGODB_DR_DATABASES=

# Redis DR
REDIS_DR_HOST=localhost
REDIS_DR_PORT=6379
REDIS_DR_PASSWORD=
REDIS_DR_DB=0

# GPU DR
GPU_DR_IMAGE_NAMES=
GPU_DR_VOLUME_NAMES=

# === Encryption Key Generation ===
# Generate encryption keys using:
# openssl rand -hex 32
# 
# Store keys securely (e.g., AWS Secrets Manager, HashiCorp Vault)
# DO NOT commit encryption keys to version control

